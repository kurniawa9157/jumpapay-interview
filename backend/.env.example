# --- App ---
APP_ENV=development
APP_PORT=8080
APP_FRONTEND_ORIGIN=http://localhost:5173
GOOGLE_CLIENT_ID=

# --- Postgres ---
# Native install (Windows): default port 5432, user postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=template_base
DB_SSLMODE=disable
DB_MAX_CONNS=10

# --- Redis ---
# Laragon ships Redis di c:/laragon/bin/redis — jalankan via Laragon UI
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- JWT ---
# WAJIB diganti di production. Generate: openssl rand -base64 64
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- Super admin seed (dipakai di migration seeder) ---
SEED_ADMIN_EMAIL=admin@template.local
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_NAME=Super Admin

# --- Rate limit ---
RATE_LIMIT_PER_MINUTE=60
LOGIN_RATE_LIMIT_PER_MINUTE=10

# --- Media upload (CMS / page builder) ---
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=5

# Storage backend untuk Media Library: 'local' (default, filesystem) atau
# 's3' (S3-compatible: AWS S3, MinIO, Cloudflare R2, dll).
MEDIA_STORAGE=local

# AWS S3 / MinIO — hanya dipakai kalau MEDIA_STORAGE=s3.
# Bucket harus public-read kalau frontend mau langsung akses URL.
# MinIO: `mc anonymous set download <alias>/<bucket>` untuk public-read.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
# AWS_URL = public-facing prefix lengkap (endpoint + bucket). Dipakai
# untuk build URL respons. Mis. https://storage.example.com/template-asset
AWS_URL=
# MinIO requires path-style (true). AWS S3 native support virtual-hosted
# style juga jadi false; pakai true kalau ragu.
AWS_USE_PATH_STYLE_ENDPOINT=false
