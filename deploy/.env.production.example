# ═══════════════════════════════════════════════════════════════
# e-PPAT Production Deployment — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy file ini menjadi .env (TIDAK di-commit ke git), lalu isi nilai
# rahasia sesuai server Anda.
#
#   cp .env.production.example .env
#   nano .env
#
# ═══════════════════════════════════════════════════════════════

# --- PostgreSQL (internal) ---
# Password ini hanya dipakai antar container. Tidak di-expose ke publik.
DB_USER=eppat
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
DB_NAME=eppat

# --- JWT ---
# Generate di server: openssl rand -base64 64
JWT_SECRET=GANTI_DENGAN_openssl_rand_base64_64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- CORS allow-list ---
# Hostname + skema yang dipakai browser saat akses frontend.
# Untuk deploy di VPS dengan TLS: https://eppat.example.com
APP_FRONTEND_ORIGIN=https://eppat.example.com

# --- Super admin seed (dipakai service `seed` sekali) ---
SEED_ADMIN_EMAIL=admin@eppat.id
SEED_ADMIN_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT
SEED_ADMIN_NAME=Admin ATR/BPN

# --- Rate limit global per IP per menit ---
RATE_LIMIT_PER_MINUTE=120
LOGIN_RATE_LIMIT_PER_MINUTE=15

# --- Frontend build args ---
# Default "/api/v1" (same-origin, nginx frontend proxy ke backend).
# Ganti jika frontend & backend di origin berbeda, misal: https://api.eppat.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# --- Port HTTP yang di-expose ke host ---
# Production dengan reverse proxy TLS (Caddy/nginx/traefik) di depan: 80 atau 8080
# Langsung tanpa reverse proxy: 80 (tapi no TLS — tidak direkomendasi untuk produksi)
HTTP_PORT=80

# --- Image tag untuk backend & frontend ---
# Berguna kalau Anda push ke registry + pakai tag version.
IMAGE_TAG=latest
